{
  "name": "@tetherto/wdk-wallet-sui",
  "version": "1.0.0-beta.1",
  "description": "A simple package to manage BIP-32 wallets for the SUI blockchain.",
  "keywords": [
    "wdk",
    "wallet",
    "bip-32",
    "sui"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "main": "index.js",
  "type": "module",
  "types": "./types",
  "scripts": {
    "build:types": "tsc",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathIgnorePatterns=integration",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/*.test.js --testPathIgnorePatterns=integration",
    "test:brittle": "brittle tests/*.js",
    "test:integration": "brittle tests/integration/*.js",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --testPathIgnorePatterns=integration"
  },
  "dependencies": {
    "@mysten/sui": "^1.21.1",
    "@tetherto/wdk-failover-provider": "1.0.0-beta.2",
    "@tetherto/wdk-wallet": "1.0.0-beta.7",
    "bare-node-runtime": "^1.1.4",
    "bip39": "3.1.0",
    "micro-key-producer": "0.7.6",
    "sodium-universal": "5.0.1"
  },
  "devDependencies": {
    "brittle": "^3.0.0",
    "cross-env": "7.0.3",
    "jest": "^30.2.0",
    "standard": "17.1.2",
    "typescript": "5.8.3"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "bare": "./bare.js",
      "default": "./index.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "standard": {
    "ignore": [
      "bare.js",
      "tests/**/*.js"
    ]
  }
}
